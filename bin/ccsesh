#!/usr/bin/env bash
set -u

CCSESH_VERSION="0.1.0"

# Resolve repo dir through symlink (install.sh symlinks bin/ccsesh into PATH).
SOURCE="${BASH_SOURCE[0]}"
while [ -h "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in /*) ;; *) SOURCE="$DIR/$SOURCE" ;; esac
done
CCSESH_DIR="$(cd -P "$(dirname "$SOURCE")/.." && pwd)"

# shellcheck disable=SC1091
. "$CCSESH_DIR/lib/util.sh"
# shellcheck disable=SC1091
. "$CCSESH_DIR/lib/sessions.sh"
# shellcheck disable=SC1091
. "$CCSESH_DIR/lib/ui.sh"

usage() {
  cat <<EOF
Usage: ccsesh [options]

Fuzzy-search every Claude Code session on this machine and resume the
selected one.

Options:
  --list              Print all sessions as TSV and exit (scripting).
  --project <path>    Restrict to sessions whose original cwd matches <path>.
  --since <spec>      Only sessions with recency newer than <spec> (Nd, Nh, Nm).
  -h, --help          Show this help.
  -v, --version       Print version.
  --debug             Write timing + phase info to /tmp/ccsesh-debug.log.

Environment:
  CCSESH_CLAUDE_HOME  Override the Claude home dir (default: \$HOME/.claude).
EOF
}

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || { printf 'ccsesh: missing required command %q (install with: %s)\n' "$1" "$2" >&2; exit 127; }
}

ccsesh_main() {
  local mode="interactive"
  local project="" since=""
  _ccsesh_debug "ccsesh: start argv=$*"
  while [ $# -gt 0 ]; do
    case "$1" in
      __preview)
        # Hidden: called by fzf preview. Args: __preview <cwd> <sid> [<query>]
        # Query may contain filter tokens (repo:X, since:Y) that should NOT
        # be highlighted in the preview — strip them first.
        shift
        local _cwd="$1" _sid="$2" _q="${3:-}"
        local _q_clean=""
        local _tok
        for _tok in $_q; do
          case "$_tok" in
            repo:*|since:*|name:*) ;;
            *) _q_clean="${_q_clean:+$_q_clean }$_tok" ;;
          esac
        done
        local home; home="$(ccsesh_home)"
        local f
        for f in "$home/projects"/*/"$_sid".jsonl; do
          [ -f "$f" ] || continue
          ccsesh_ui_preview "$f" "$_q_clean"
          exit 0
        done
        printf '(session file not found)\n'
        exit 0
        ;;
      __help)
        # Hidden: rendered by fzf's Ctrl-G / Ctrl-/ bind as a transient help
        # overlay in the preview pane. Any keystroke in the query field fires
        # `change` which re-runs __preview, so help auto-dismisses on typing.
        cat <<'HELP'

[1;36m┌──────────────  ccsesh cheat sheet  ──────────────┐[0m

[1;33mKEYBINDINGS[0m
  [36mEnter[0m        Resume selected session (cd + claude --resume)
  [36mCtrl-O[0m       Print sessionId and cwd, then exit (scripting)
  [36mCtrl-G[0m[2m / [0m[36mCtrl-/[0m   Show this help (dismiss by typing)
  [36mEsc[0m          Quit

[1;33mFILTER TOKENS[0m
  [32mrepo:X[0m       project dir basename contains X (case-insensitive)
  [32msince:Nd[0m     recent N days (also [32mNh[0m, [32mNm[0m)
  [32mname:X[0m       custom title contains X (sessions without a title are excluded)

[1;33mFREE-TEXT OPERATORS[0m  [2m(fzf, always case-insensitive)[0m
  [35mfoo bar[0m      AND — both must match
  [35m'foo[0m         exact substring match for foo
  [35m^foo[0m         foo at start of line
  [35mfoo$[0m         foo at end of line
  [35m!foo[0m         must NOT contain foo

[1;33mEXAMPLES[0m
  [2m#[0m find sessions mentioning transcript, narrowed to one repo
  transcript repo:claude-skills

  [2m#[0m recent sessions, excluding anything about bugwatch
  since:7d !bugwatch

  [2m#[0m only sessions I renamed with "bugwatch" in the title
  name:bugwatch

[1;33mPREVIEW SCROLLING[0m
  When your query matches something, the body below the header
  opens at the first matching line. Otherwise it shows the top.
  Filter tokens ([2mrepo:[0m, [2msince:[0m, [2mname:[0m) are stripped before
  highlighting — they don't pollute match colors.

[2m───────────────────────────────────────────────────[0m
[2mStart typing to dismiss this help and return to preview.[0m

HELP
        exit 0
        ;;
      __fzf_feed)
        # Hidden: called by fzf's change:reload bind. Args: __fzf_feed [<query>]
        # Reads from $CCSESH_UI_CACHE (set by ccsesh_ui_run), parses the query
        # for filter tokens (repo:X, since:Nd|Nh|Nm), applies them plus any
        # remaining text terms, and prints the filtered TSV.
        shift
        local _q="${*:-}"
        local cache="${CCSESH_UI_CACHE:-}"
        if [ -z "$cache" ] || [ ! -r "$cache" ]; then
          # No cache — either ccsesh_ui_run did not run, or it failed. Silent.
          exit 0
        fi
        local _repo="" _since="" _name="" _text=""
        local _tok
        for _tok in $_q; do
          case "$_tok" in
            repo:*)  _repo="${_tok#repo:}" ;;
            since:*) _since="${_tok#since:}" ;;
            name:*)  _name="${_tok#name:}" ;;
            *)       _text="${_text:+$_text }$_tok" ;;
          esac
        done

        local _cutoff=""
        if [ -n "$_since" ]; then
          local _sec
          _sec="$(_ccsesh_since_to_seconds "$_since" 2>/dev/null)" || _sec=""
          [ -n "$_sec" ] && _cutoff="$(( $(date +%s) - _sec ))"
        fi

        # Apply repo + since + name filters via awk on the cache.
        # Cache fields: 1=sid 2=cwd 3=ts_iso 4=display 5=epoch 6=custom_title.
        local _filtered
        _filtered="$(awk -F'\t' -v OFS='\t' \
             -v repo="$_repo" -v cutoff="${_cutoff:-}" -v name="$_name" '
          BEGIN {
            if (repo != "") repo_lc = tolower(repo)
            if (name != "") name_lc = tolower(name)
          }
          {
            if (repo != "") {
              n = split($2, p, "/"); base = tolower(p[n])
              if (index(base, repo_lc) == 0) next
            }
            if (cutoff != "" && ($5+0) < (cutoff+0)) next
            if (name != "") {
              title_lc = tolower($6)
              if (index(title_lc, name_lc) == 0) next
            }
            print
          }
        ' "$cache")"

        if [ -z "$_filtered" ]; then
          exit 0
        fi

        # Apply text-match via fzf --filter. --tiebreak=index preserves the
        # recency-desc order from the cache. --with-nth=4 scopes matching to
        # the visible display field. -i forces case-insensitive.
        if [ -n "$_text" ]; then
          printf '%s\n' "$_filtered" \
            | fzf --filter="$_text" \
                  -i \
                  --delimiter=$'\t' \
                  --with-nth=4 \
                  --tiebreak=index 2>/dev/null
        else
          printf '%s\n' "$_filtered"
        fi
        exit 0
        ;;
      --list) mode=list; shift ;;
      --project) project="$2"; shift 2 ;;
      --since) since="$2"; shift 2 ;;
      -h|--help) usage; exit 0 ;;
      -v|--version) printf 'ccsesh %s\n' "$CCSESH_VERSION"; exit 0 ;;
      --debug) CCSESH_DEBUG=1; export CCSESH_DEBUG; shift ;;
      --) shift; break ;;
      -*) printf 'ccsesh: unknown flag %q (see --help)\n' "$1" >&2; exit 2 ;;
      *) printf 'ccsesh: unexpected argument %q (see --help)\n' "$1" >&2; exit 2 ;;
    esac
  done

  _ccsesh_debug "ccsesh: parsed mode=$mode project=$project since=$since"
  require_cmd jq 'brew install jq (macOS) or apt/dnf/pacman install jq (Linux)'

  local args=()
  [ -n "$project" ] && args+=(--project "$project")
  [ -n "$since" ] && args+=(--since "$since")

  case "$mode" in
    list)
      ccsesh_sessions_list ${args[@]:+"${args[@]}"}
      ;;
    interactive)
      require_cmd fzf 'brew install fzf (macOS) or apt/dnf/pacman install fzf (Linux)'
      ccsesh_ui_run ${args[@]:+"${args[@]}"}
      ;;
  esac
}

ccsesh_main "$@"
